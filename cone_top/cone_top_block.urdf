<?xml version="1.0" ?>
<robot name="cone_top_block">
  <link name="cone_top_link">
    <contact>
      <lateral_friction value="3.0"/>
      <rolling_friction value="0.0"/>
      <contact_cfm value="0.0"/>
      <contact_erp value="1.0"/>
    </contact>
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0.0115"/>
      <mass value="0.12"/>
      <inertia ixx="0.00012" ixy="0" ixz="0" iyy="0.00012" iyz="0" izz="0.00012"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="cone_top.obj" scale="1 1 1"/>
      </geometry>
      <material name="roof_block">
        <color rgba="0.6 0.6 0.6 1"/>
      </material>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="cone_top.obj" scale="1 1 1"/>
      </geometry>
    </collision>
  </link>
</robot>
